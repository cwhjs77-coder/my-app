rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────
    // 공통 헬퍼 함수
    // ─────────────────────────────────────────────────

    // 로그인 여부
    function isSignedIn() {
      return request.auth != null;
    }

    // 현재 요청 사용자의 프로필 문서
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // 관리자 여부 (role == "admin" 또는 환경변수 ADMIN_UID 처리는 클라이언트 담당)
    function isAdmin() {
      return isSignedIn() && userDoc().role == "admin";
    }

    // 승인된 매니저 여부
    function isApprovedManager() {
      return isSignedIn()
        && userDoc().role == "manager"
        && userDoc().approved == true;
    }

    // 일반 승인 사용자 (admin / 승인된 manager / member)
    function isApprovedUser() {
      return isSignedIn()
        && userDoc().approved == true;
    }

    // ─────────────────────────────────────────────────
    // users 컬렉션
    // ─────────────────────────────────────────────────
    match /users/{uid} {
      // 본인 프로필 읽기, 관리자는 전체 읽기
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      // 회원가입 시 본인 문서 생성
      allow create: if isSignedIn() && request.auth.uid == uid;

      // 본인 프로필 수정 (role, approved 필드는 본인이 변경 불가)
      allow update: if isSignedIn() && request.auth.uid == uid
        && !("role" in request.resource.data.diff(resource.data).affectedKeys())
        && !("approved" in request.resource.data.diff(resource.data).affectedKeys());

      // 관리자: 승인(approved) 및 role 변경 허용
      allow update: if isAdmin();

      // 삭제는 관리자만
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────
    // organizations 컬렉션
    // ─────────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedManager() || isAdmin();
      allow update: if isAdmin()
        || (isApprovedManager() && resource.data.managerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────
    // human_resources 컬렉션
    // ─────────────────────────────────────────────────
    match /human_resources/{docId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedManager() || isAdmin();
      allow update: if isAdmin()
        || (isApprovedManager() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin()
        || (isApprovedManager() && resource.data.createdBy == request.auth.uid);
    }

    // ─────────────────────────────────────────────────
    // physical_resources 컬렉션
    // ─────────────────────────────────────────────────
    match /physical_resources/{docId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedManager() || isAdmin();
      allow update: if isAdmin()
        || (isApprovedManager() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin()
        || (isApprovedManager() && resource.data.createdBy == request.auth.uid);
    }

    // ─────────────────────────────────────────────────
    // ideas 컬렉션
    // ─────────────────────────────────────────────────
    match /ideas/{docId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isAdmin()
        || resource.data.authorId == request.auth.uid;
      allow delete: if isAdmin()
        || resource.data.authorId == request.auth.uid;
    }

    // ─────────────────────────────────────────────────
    // talent_posts 컬렉션 (인재·채용)
    // ─────────────────────────────────────────────────
    match /talent_posts/{docId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedManager() || isAdmin();
      allow update: if isAdmin()
        || (isApprovedManager() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin()
        || (isApprovedManager() && resource.data.createdBy == request.auth.uid);
    }

    // ─────────────────────────────────────────────────
    // notices 컬렉션 (공지·공고)
    // ─────────────────────────────────────────────────
    match /notices/{noticeId} {
      allow read: if isApprovedUser();
      // 서버 API 라우트에서 Admin SDK로 생성 → 클라이언트 직접 write 불필요
      // 직접 등록은 관리자/매니저만 허용
      allow create: if isApprovedManager() || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────
    // notifications 컬렉션 (개인 알림함)
    // ─────────────────────────────────────────────────
    match /notifications/{notifId} {
      // 본인 알림만 읽기/수정(읽음 처리), 삭제는 본인 또는 관리자
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      // 생성은 서버(Admin SDK) 또는 관리자
      allow create: if isAdmin();
    }

    // ─────────────────────────────────────────────────
    // chats 컬렉션 — 1:1 비밀채팅
    // chatId = sorted(uid1, uid2).join("_")
    // ─────────────────────────────────────────────────
    match /chats/{chatId} {
      // 채팅방 participants 배열에 본인 uid가 포함된 경우만 읽기 허용
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      // 채팅방 생성: 참여자 중 한 명이 본인이어야 함
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;

      // 채팅방 메타(unreadCount 등) 업데이트: 참여자만
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow delete: if isAdmin();

      // 메시지 서브컬렉션
      match /messages/{messageId} {
        // 상위 채팅방 participants 에 포함된 경우만 읽기/쓰기
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderId == request.auth.uid;

        allow update: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow delete: if isAdmin()
          || (isSignedIn() && resource.data.senderId == request.auth.uid);
      }
    }

    // ─────────────────────────────────────────────────
    // feedback 컬렉션
    // ─────────────────────────────────────────────────
    match /feedback/{docId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser();
      allow update: if isAdmin()
        || resource.data.authorId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────
    // networking_posts 컬렉션 — 네트워킹 게시판
    // ─────────────────────────────────────────────────
    match /networking_posts/{postId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isAdmin()
        || (isApprovedUser() && resource.data.authorId == request.auth.uid);
      allow delete: if isAdmin()
        || (isApprovedUser() && resource.data.authorId == request.auth.uid);

      // 댓글 서브컬렉션
      match /comments/{commentId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser()
          && request.resource.data.authorId == request.auth.uid;
        allow delete: if isAdmin()
          || (isApprovedUser() && resource.data.authorId == request.auth.uid);
        allow update: if false;
      }
    }

    // ─────────────────────────────────────────────────
    // push_logs 컬렉션 — FCM 발송 이력 (Admin SDK 기록)
    // 클라이언트 직접 write 금지, admin만 read 가능
    // ─────────────────────────────────────────────────
    match /push_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Admin SDK에서만 기록
    }

    // ─────────────────────────────────────────────────
    // 그 외 모든 경로 — 기본 거부
    // ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
